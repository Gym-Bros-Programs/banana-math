{
  "private": true,
  "scripts": {
    "dev": "node scripts/start-ui.js",
    "dev:db": "node scripts/start-db.js",
    "dev:cloud": "node scripts/start-cloud.js",
    "db:start": "npx supabase start",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm test -- --run && npm run build",
    "db:reset": "node scripts/db-reset.js",
    "db:schema": "node scripts/db-reset.js --skip-questions",
    "db:restore": "node scripts/db-restore.js",
    "db:restore:only": "node scripts/db-restore.js --only",
    "db:generate": "node scripts/question-gen/index.js generate",
    "db:generate:easy": "node scripts/question-gen/index.js generate --difficulty=Easy --ops=addition,subtraction,multiplication,division",
    "db:generate:medium": "node scripts/question-gen/index.js generate --difficulty=Medium --ops=addition,subtraction,multiplication,division",
    "db:generate:hard": "node scripts/question-gen/index.js generate --difficulty=Hard --ops=addition,subtraction,multiplication,division",
    "db:seed": "node scripts/question-gen/index.js upload scripts/question-gen/output/questions_easy.json",
    "db:seed:medium": "node scripts/question-gen/index.js upload scripts/question-gen/output/questions_medium.json",
    "db:seed:hard": "node scripts/question-gen/index.js upload scripts/question-gen/output/questions_hard.json",
    "db:seed:prod": "node scripts/question-gen/index.js upload --target=prod",
    "db:seed:medium:prod": "node scripts/question-gen/index.js upload scripts/question-gen/output/questions_medium.json --target=prod",
    "db:seed:hard:prod": "node scripts/question-gen/index.js upload scripts/question-gen/output/questions_hard.json --target=prod",
    "db:generate-and-seed": "npm run db:generate:easy && npm run db:seed",
    "db:seed:all": "node scripts/seed-all.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "eslintConfig": {
    "extends": "./config/eslint/.eslintrc.json"
  },
  "prettier": "./config/prettier/.prettierrc.json",
  "frozen": {
    "comment": "These versions are intentionally frozen and should not be updated without review",
    "dependencies": {
      "@supabase/supabase-js": "2.46.2",
      "@supabase/ssr": "0.5.2",
      "next": "15.2.2"
    }
  },
  "dependencies": {
    "@geist-ui/react": "2.2.5",
    "@supabase/ssr": "0.5.2",
    "@supabase/supabase-js": "2.53.0",
    "autoprefixer": "10.4.20",
    "baseline-browser-mapping": "2.10.23",
    "caniuse-lite": "1.0.30001791",
    "dotenv": "17.2.1",
    "geist": "1.4.2",
    "next": "14.2.31",
    "postcss": "8.4.47",
    "react": "18.3.1",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.12.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "encoding": "^0.1.13",
    "eslint": "8.57.1",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.3",
    "jsdom": "29.1.0",
    "prettier": "3.6.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5"
  }
}
